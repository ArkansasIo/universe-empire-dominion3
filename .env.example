# Database Configuration
# Use DATABASE_URL for Neon/PostgreSQL connection
DATABASE_URL=postgresql://username:password@host:5432/database_name

# OR use individual PostgreSQL variables
PGHOST=localhost
PGPORT=5432
PGDATABASE=stellar_dominion
PGUSER=postgres
PGPASSWORD=postgres

# Server Configuration
NODE_ENV=development
PORT=5000

# Session Secret (IMPORTANT: Change this in production!)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Logging Configuration
LOG_LEVEL=info
LOG_QUERIES=false
DEBUG=false

# Admin Configuration (set during deployment)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here

# Optional: Replit-specific (if deploying on Replit)
REPL_ID=
REPL_OWNER=
REPLIT_DB_URL=
